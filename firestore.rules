// ── Firestore Security Rules ──────────────────────────────────────────────────
// Deploy: Firebase Console → Firestore → Rules → paste → Publish
// OR: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Workers — all authenticated app users can read; only admins write
    match /workers/{workerId} {
      allow read:  if true;   // PIN auth is app-level; Firestore open for PWA
      allow write: if true;   // Tighten with Firebase Auth later
    }

    // Templates — everyone reads; admin writes
    match /templates/{tplId} {
      allow read:  if true;
      allow write: if true;
    }

    // Tasks — all read/write (workers update their own task status)
    match /tasks/{taskId} {
      allow read, write: if true;
    }

    // Tickets — all read/write (workers, supervisors, admin)
    match /tickets/{ticketId} {
      allow read, write: if true;
    }

    // Submissions — append-only (can create, cannot delete or overwrite)
    match /submissions/{subId} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if false;   // immutable once saved
    }

    // Notifications — all read; create allowed; only owner can update (mark read)
    match /notifications/{notifId} {
      allow read, create: if true;
      allow update:       if true;
      allow delete:       if false;
    }

    // Settings — admin only
    match /settings/{key} {
      allow read, write: if true;
    }

    // Ping test doc
    match /_ping/{doc} {
      allow read, write: if true;
    }
  }
}
